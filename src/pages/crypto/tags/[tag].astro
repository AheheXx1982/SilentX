---
import HomeSider from '@components/layout/HomeSider.astro';
import Cover from '@components/ui/cover/Cover.astro';
import { siteConfig } from '@constants/site-config';
import Layout from '@layouts/Layout.astro';
import TwoColumnLayout from '@layouts/TwoColumnLayout.astro';
import { getSortedCryptos } from '@lib/content';
import { parseDate } from '@lib/datetime';

export async function getStaticPaths() {
  const cryptos = await getSortedCryptos();
  const tags = new Set<string>();

  cryptos.forEach((crypto) => {
    const cryptoTags = crypto.data.tags || [];
    cryptoTags.forEach((tag) => tags.add(tag));
  });

  return Array.from(tags).map((tag) => ({
    params: { tag: tag.replace(/\//g, '-') },
    props: {
      cryptos: cryptos.filter((crypto) => crypto.data.tags?.includes(tag)),
      tag,
    },
  }));
}

const { tag, cryptos } = Astro.props;
---

<Layout title={`加密货币标签:${tag} | ${siteConfig.title}`} description={`标签 ${tag} 下的所有加密货币分析`}>
  <TwoColumnLayout>
    <Cover slot="cover" title={`包含标签"${tag}"的加密货币分析`} />
    <HomeSider slot="sider" />
    <div class="shadow-box bg-gradient-start mx-0 flex w-full flex-col px-6 py-4 md:px-3 md:py-2">
      <h2 class="shoka-decoration-circle has-children group relative h-19 px-7.5 py-5 text-2xl/9 font-bold">
        <a
          href={Astro.url.origin + '/crypto/tags'}
          class="dashed-border text-muted-foreground group-hover:border-blue group-hover:text-blue border-b">全部</a
        >
        <span class="text-muted-foreground text-lg"> / </span>
        <span class="text-muted-foreground">{tag}</span>
        <span class="text-muted-foreground text-lg">({cryptos.length} 篇分析)</span>
      </h2>
      {
        cryptos?.length && (
          <div class="category-second-level-container flex flex-col">
            {cryptos.map((crypto) => {
              return (
                <p class="shoka-decoration-circle group text-primary relative px-7.5 py-2 text-base/9 md:overflow-visible">
                  <span class="text-muted-foreground inline-block w-15 text-xs md:relative md:-top-1">
                    {parseDate(crypto?.data?.date, 'YY-MM-DD')}
                  </span>
                  <span class="text-muted-foreground mr-2 inline-block text-xs md:relative md:-top-1">
                    {crypto?.data?.symbol}
                  </span>
                  <a href={'/crypto/' + crypto?.slug} class="dashed-border md:absolute md:top-7 md:left-7">
                    {crypto?.data?.title}
                  </a>
                </p>
              );
            })}
          </div>
        )
      }
    </div>
  </TwoColumnLayout>
</Layout>
