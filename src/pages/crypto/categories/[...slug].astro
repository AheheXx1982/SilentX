---
import CategoryPostList from '@components/category/CategoryPostList.astro';
import HomeSider from '@components/layout/HomeSider.astro';
import Cover from '@components/ui/cover/Cover.astro';
import { seoConfig } from '@constants/site-config';
import Layout from '@layouts/Layout.astro';
import TwoColumnLayout from '@layouts/TwoColumnLayout.astro';
import { getCategoryByLink, getCategoryLinks, getCryptoCategoryList } from '@lib/content';

// 获取加密货币分类页面
export async function getStaticPaths() {
  const { categories } = await getCryptoCategoryList();
  const links = getCategoryLinks(categories, '');
  return links.map((link) => {
    const category = getCategoryByLink(categories, link);
    return {
      params: { slug: link },
      props: { category },
    };
  });
}

const { category } = Astro.props;
const { categories: allCategories, countMap } = await getCryptoCategoryList();

// 如果是子分类，只展示当前分类的内容
const displayCategories = category ? [category] : allCategories;
---

<Layout title={`加密货币分类 - ${category?.name} | ${seoConfig.title}`}>
  <TwoColumnLayout>
    <Cover slot="cover" title={`分类于"${category?.name}"的加密货币分析`} />
    <HomeSider slot="sider" />
    <CategoryPostList rootCategory={category} categories={displayCategories} countMap={countMap} />
  </TwoColumnLayout>
</Layout>
