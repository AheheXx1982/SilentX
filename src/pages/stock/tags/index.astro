---
import HomeSider from '@components/layout/HomeSider.astro';
import Cover from '@components/ui/cover/Cover.astro';
import { siteConfig } from '@constants/site-config';
import Layout from '@layouts/Layout.astro';
import TwoColumnLayout from '@layouts/TwoColumnLayout.astro';
import { getAllStockTags, getSortedStocks } from '@lib/content';

const TAG_COLORS = [
  'from-green-400/10 to-emerald-300/10 hover:from-green-400/80 hover:to-emerald-300/80 text-green-400/70 hover:text-green-50',
  'from-orange-300/10 to-amber-200/10 hover:from-orange-300/80 hover:to-amber-200/80 text-orange-400/70 hover:text-orange-50',
  'from-red-400/10 to-rose-300/10 hover:from-red-400/80 hover:to-rose-300/80 text-red-400/70 hover:text-red-50',
  'from-purple-400/10 to-violet-300/10 hover:from-purple-400/80 hover:to-violet-300/80 text-purple-400/70 hover:text-purple-50',
];

const stocks = await getSortedStocks();
const tags = getAllStockTags(stocks);
const sortedTags = Object.entries(tags)
  .sort(([, a], [, b]) => b - a)
  .map(([tag, count]) => ({ tag, count }));
---

<Layout title={`股票标签 | ${siteConfig.title}`} description="所有股票分析标签">
  <TwoColumnLayout>
    <Cover slot="cover" title="股票标签" />
    <HomeSider slot="sider" />
    <div class="shadow-box bg-gradient-start mx-0 flex w-full flex-col px-6 py-4 md:px-3 md:py-2">
      <h2 class="shoka-decoration-circle group relative h-19 px-7.5 py-5 text-2xl/9 font-bold">
        <a href="/stock" class="dashed-border text-muted-foreground group-hover:border-blue group-hover:text-blue border-b"
          >股票分析</a
        >
        <span class="text-muted-foreground text-lg"> / </span>
        目前共计 {sortedTags.length} 个标签
      </h2>
      <div class="flex flex-wrap gap-3 p-4">
        {
          sortedTags.map(({ tag, count }, index) => (
            <div class="group relative">
              {/* 防止闪烁 */}
              <a
                href={`/stock/tags/${tag.replace(/\//g, '-')}`}
                class={`group relative flex items-center rounded-lg bg-linear-to-r px-3 py-1.5 text-sm transition-all duration-300 group-hover:-translate-y-0.5 group-hover:shadow-lg ${
                  TAG_COLORS[index % TAG_COLORS.length]
                }`}
              >
                <span class="font-medium">{tag}</span>
                <span class="ml-1.5 truncate rounded-full bg-white/10 px-1.5 text-xs">{count}</span>
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </TwoColumnLayout>
</Layout>
